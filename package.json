{
  "name": "orvaxis",
  "version": "0.2.4",
  "description": "Lightweight policy-driven execution runtime for Node.js",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/esm/testing.d.ts",
        "default": "./dist/esm/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maku85/orvaxis.git"
  },
  "keywords": [
    "policy",
    "middleware",
    "router",
    "runtime",
    "express",
    "fastify",
    "nodejs"
  ],
  "scripts": {
    "dev": "tsx examples/express-server.ts",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json && node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'}))\"",
    "build": "pnpm build:cjs && pnpm build:esm",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench benchmarks/",
    "bench:run": "vitest bench run benchmarks/",
    "bench:save": "tsx benchmarks/compare.ts --save",
    "bench:compare": "tsx benchmarks/compare.ts --compare",
    "prepublishOnly": "npm run check && tsc --noEmit && npm run test && npm run build",
    "release": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "release:alpha": "bash scripts/release.sh prerelease alpha"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.0.0",
    "express": "^4.20.0 || ^5.0.0",
    "fastify": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@opentelemetry/api": "^1.9.1",
    "@types/express": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "fastify": "^5.8.5",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.1.2"
}
