{
  "name": "orvaxis",
  "version": "0.1.0",
  "description": "Lightweight policy-driven execution runtime for Node.js",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maku85/orvaxis.git"
  },
  "keywords": [
    "policy",
    "middleware",
    "router",
    "runtime",
    "express",
    "fastify",
    "nodejs"
  ],
  "scripts": {
    "dev": "tsx examples/express-server.ts",
    "build": "tsc",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench benchmarks/",
    "bench:run": "vitest bench run benchmarks/",
    "bench:save": "tsx benchmarks/compare.ts --save",
    "bench:compare": "tsx benchmarks/compare.ts --compare",
    "prepublishOnly": "npm run check && tsc --noEmit && npm run test && npm run build",
    "release": "npm publish",
    "release:alpha": "npm publish --tag alpha"
  },
  "peerDependencies": {
    "express": "^4.19.0",
    "fastify": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/express": "^4.17.0",
    "@vitest/coverage-v8": "^4.1.5",
    "fastify": "^5.8.5",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
