{
  "name": "orvaxis",
  "version": "0.1.0",
  "description": "Lightweight policy-driven execution runtime for Node.js",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx examples/express-server.ts",
    "build": "tsc",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "express": "^4.19.0",
    "fastify": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/express": "^4.17.0",
    "fastify": "^5.8.5",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
