{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["index.ts", "core/**/*.ts", "debug/**/*.ts", "http/**/*.ts", "middleware/**/*.ts", "plugins/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "dist", "examples", "tests"]
}
